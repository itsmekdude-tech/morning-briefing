OLLAMA_HOST=http://localhost:11434
OLLAMA_CLASSIFIER_MODEL=qwen2.5:3b
OLLAMA_EXTRACTOR_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120

DB_URL=sqlite:///./data/briefing.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Where the inbox comes from. mock = local JSON, gmail = real Google API.
INBOX_SOURCE=mock
DEFAULT_PERSONA=hersh
LLM_PIPELINE_ENABLED=true

# After OAuth callback succeeds, redirect the browser here.
FRONTEND_BASE=http://localhost:5173

# Required when INBOX_SOURCE=gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/calendar.readonly

# Fernet key for at-rest encryption of refresh tokens (auto-generated on first run if blank).
TOKEN_ENCRYPTION_KEY=

# Random signed-state secret for OAuth CSRF protection (auto-generated on first run if blank).
SESSION_SECRET=
